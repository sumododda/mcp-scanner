# Database (required)
MCP_SCANNER_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mcp_scanner

# API Authentication (optional — leave empty to disable auth in dev)
MCP_SCANNER_API_KEY=

# LLM Judge via OpenRouter (optional — required for Tier 2 analysis, triage, code graph chat)
MCP_SCANNER_OPENROUTER_API_KEY=
MCP_SCANNER_OPENROUTER_MODEL=google/gemini-3.1-pro-preview
MCP_SCANNER_LLM_JUDGE_ENABLED=true

# ML Classification via HuggingFace (optional)
MCP_SCANNER_HUGGINGFACE_API_TOKEN=
MCP_SCANNER_ML_CLASSIFIER_ENABLED=false

# Scan limits
MCP_SCANNER_SCAN_TIMEOUT_SECONDS=300
MCP_SCANNER_MAX_REPO_SIZE_MB=500

# CORS
MCP_SCANNER_CORS_ORIGINS=["http://localhost:3000"]
